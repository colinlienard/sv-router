{
	"name": "sv-router",
	"version": "0.17.0",
	"description": "Type-safe routing for Svelte SPAs",
	"keywords": [
		"router",
		"spa",
		"svelte"
	],
	"homepage": "https://github.com/colinlienard/sv-router",
	"bugs": {
		"url": "https://github.com/colinlienard/sv-router/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/colinlienard/sv-router.git"
	},
	"bin": "./src/cli/index.js",
	"files": [
		"src"
	],
	"type": "module",
	"exports": {
		".": {
			"import": "./src/index.js",
			"svelte": "./src/index.js",
			"types": "./src/index.d.ts"
		},
		"./vite-plugin": {
			"import": "./src/vite-plugin/index.js",
			"types": "./src/vite-plugin/index.d.ts"
		}
	},
	"scripts": {
		"create:dev": "pnpm --filter create-sv-router dev",
		"create:build": "pnpm --filter create-sv-router build",
		"docs:dev": "pnpm --filter docs dev",
		"docs:build": "pnpm --filter docs build",
		"docs:preview": "pnpm --filter docs preview",
		"test": "vitest",
		"test:coverage": "vitest run --coverage",
		"check": "svelte-check && pnpm -r check",
		"lint": "eslint . --max-warnings 0",
		"lint:fix": "eslint . --fix",
		"format": "oxfmt --check",
		"format:fix": "oxfmt",
		"changeset": "changeset"
	},
	"dependencies": {
		"esm-env": "^1.2.2"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@eslint/js": "^10.0.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^24.12.4",
		"@vitest/coverage-v8": "^4.1.7",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"eslint-plugin-svelte": "^3.18.0",
		"eslint-plugin-unicorn": "^66.0.0",
		"globals": "^17.6.0",
		"happy-dom": "^20.9.0",
		"oxfmt": "^0.52.0",
		"svelte-check": "^4.4.8",
		"type-testing": "^0.2.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0",
		"vite": "^8.0.14",
		"vitest": "^4.1.7"
	},
	"peerDependencies": {
		"svelte": "^5"
	},
	"packageManager": "pnpm@11.4.0"
}
